{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "shadcn": {
      "enabled": true,
      "type": "local",
      "command": "npx",
      "args": [
        "shadcn@latest",
        "mcp"
      ]
    },
    "shadcn-community": {
      "enabled": true,
      "type": "local",
      "command": "npx",
      "args": [
        "-y",
        "@jpisnice/shadcn-ui-mcp-server"
      ]
    }
  },
  "instructions": [
    "AGENTS.md"
  ]
}