{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "directus": {
      "enabled": true,
      "type": "remote",
      "url": "{env:NEXT_PUBLIC_DIRECTUS_URL}/mcp",
      "headers": {
        "Authorization": "Bearer {env:DIRECTUS_ADMIN_TOKEN}"
      }
    },
    "trigger-dev": {
      "enabled": true,
      "type": "local",
      "command": "npx",
      "args": [
        "trigger.dev@latest",
        "mcp"
      ],
      "env": {
        "TRIGGER_ACCESS_TOKEN": "{env:TRIGGER_SECRET_KEY}",
        "TRIGGER_API_URL": "{env:TRIGGER_API_URL}"
      }
    }
  },
  "instructions": [
    "AGENTS.md"
  ]
}