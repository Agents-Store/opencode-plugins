{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "firecrawl": {
      "enabled": true,
      "type": "local",
      "command": "npx",
      "args": [
        "-y",
        "firecrawl-mcp"
      ],
      "env": {
        "FIRECRAWL_API_KEY": "{env:FIRECRAWL_API_TOKEN}"
      }
    },
    "exa": {
      "enabled": true,
      "type": "local",
      "command": "npx",
      "args": [
        "-y",
        "exa-mcp-server"
      ],
      "env": {
        "EXA_API_KEY": "{env:EXA_API_KEY}"
      }
    },
    "perplexity": {
      "enabled": true,
      "type": "local",
      "command": "npx",
      "args": [
        "-y",
        "@perplexity-ai/mcp-server"
      ],
      "env": {
        "PERPLEXITY_API_KEY": "{env:PERPLEXITY_API_KEY}"
      }
    },
    "jina": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.jina.ai/v1",
      "headers": {
        "Authorization": "Bearer {env:JINA_API_KEY}"
      }
    },
    "context7": {
      "enabled": true,
      "type": "local",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "${CONTEXT7_API_KEY}"
      ]
    }
  },
  "instructions": [
    "AGENTS.md"
  ]
}